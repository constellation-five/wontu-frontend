{
  "trailingSlash": "auto",
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*", "/*.{css,js,png,jpg,svg}"]
  },
  "routes": [
    {
      "route": "/*.{js,json,css,jpg,png,ico,svg,webmanifest}",
      "headers": {
        "cache-control": "max-age=31536000"
      }
    },
    {
      "route": "/id/*",
      "rewrite": "/id/index.html"
    },
    {
      "route": "/*",
      "rewrite": "/index.html"
    }
  ]
}
