{
  "trailingSlash": "auto",
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/en/*.{js,css,ico,json}", "/en/assets/*", "/id/*.{js,css,ico,json}", "/id/assets/*"]
  },
  "routes": [
    {
      "route": "/en/*.{js,css,ico,json}",
      "headers": { "cache-control": "max-age=31536000" }
    },
    {
      "route": "/id/*.{js,css,ico,json}",
      "headers": { "cache-control": "max-age=31536000" }
    },
    {
      "route": "/en/assets/*"
    },
    {
      "route": "/id/assets/*"
    },
    {
      "route": "/en/*",
      "rewrite": "/en/index.html"
    },
    {
      "route": "/id/*",
      "rewrite": "/id/index.html"
    }
  ]
}
